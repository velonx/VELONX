      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Syne:wght@400;700;800&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/geist@1.3.0/dist/fonts/geist-sans/style.css');\n\n  :root {\n    --meade-honey: #F59E0B;\n    --nettle-green: #10B981;\n    --cloud-white: #FAFAFA;\n    --cool-slate: #1E293B;\n  }\n\n  body {\n    font-family: 'Geist Sans', sans-serif;\n    background-color: var(--cloud-white);\n    color: var(--cool-slate);\n    margin: 0;\n    overflow-x: hidden;\n  }\n\n  .font-syne {\n    font-family: 'Syne', sans-serif;\n  }\n\n  /* Noise Overlay */\n  .noise-overlay {\n    position: fixed;\n    inset: 0;\n    background-image: url(\"data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E\");\n    opacity: 0.05;\n    pointer-events: none;\n    z-index: 9999;\n  }\n\n  /* Metallic Sheen CTA */\n  .metallic-sheen {\n    position: relative;\n    overflow: hidden;\n    background: linear-gradient(135deg, var(--meade-honey) 0%, #B45309 100%);\n    color: white;\n    transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);\n  }\n\n  .metallic-sheen::after {\n    content: '';\n    position: absolute;\n    top: -50%;\n    left: -150%;\n    width: 200%;\n    height: 200%;\n    background: linear-gradient(\n      to right,\n      rgba(255,255,255,0) 0%,\n      rgba(255,255,255,0.4) 50%,\n      rgba(255,255,255,0) 100%\n    );\n    transform: rotate(30deg);\n    transition: left 0.6s ease-in-out;\n  }\n\n  .metallic-sheen:hover::after {\n    left: 100%;\n  }\n\n  .metallic-sheen:hover {\n    transform: scale(1.05) translateY(-2px);\n    box-shadow: 0 20px 40px rgba(245, 158, 11, 0.3);\n  }\n\n  /* Bento Shadow System - Wide Diffusion */\n  .honey-shadow {\n    box-shadow: 0 60px 120px -20px rgba(245, 158, 11, 0.18), 0 30px 60px -30px rgba(0,0,0,0.05);\n    transition: box-shadow 0.3s ease;\n  }\n\n  .green-shadow {\n    box-shadow: 0 60px 120px -20px rgba(16, 185, 129, 0.18), 0 30px 60px -30px rgba(0,0,0,0.05);\n    transition: box-shadow 0.3s ease;\n  }\n\n  /* Journey Path Drawing */\n  .journey-path {\n    stroke-dasharray: 3000;\n    stroke-dashoffset: 3000;\n    /* transition removed to avoid GSAP conflict */\n  }\n\n  .step-card {\n    /* transition restricted to specific properties to avoid GSAP conflict */\n    transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275), opacity 0.5s ease;\n  }\n\n  /* Carousel Blur (Depth of Field) */\n  .carousel-item {\n    transition: all 0.8s cubic-bezier(0.34, 1.56, 0.64, 1);\n    filter: blur(12px);\n    transform: scale(0.8) translateY(20px);\n    opacity: 0.4;\n    pointer-events: none;\n  }\n\n  .carousel-item.active {\n    filter: blur(0);\n    transform: scale(1.1) translateY(0);\n    opacity: 1;\n    z-index: 20;\n    pointer-events: auto;\n  }\n\n  /* Custom Scrollbar */\n  ::-webkit-scrollbar {\n    width: 6px;\n  }\n  ::-webkit-scrollbar-track {\n    background: var(--cloud-white);\n  }\n  ::-webkit-scrollbar-thumb {\n    background: var(--meade-honey);\n    border-radius: 10px;\n  }\n\n  .glass-card {\n    background: rgba(255, 255, 255, 0.7);\n    backdrop-filter: blur(20px);\n    border: 1px solid rgba(255, 255, 255, 0.3);\n  }\n</style>\n\n<div class=\"noise-overlay\" data-kid=\"1\"></div>\n\n\n<nav class=\"fixed top-0 left-0 w-full z-[100] px-12 py-8 flex justify-between items-center mix-blend-difference\" data-kid=\"2\">\n  <div class=\"font-syne font-black text-2xl tracking-tighter text-white\" data-kid=\"3\">VELONX</div>\n  <div class=\"hidden md:flex items-center gap-12 font-syne font-bold text-xs uppercase tracking-[0.2em] text-white\" data-kid=\"4\">\n    <a href=\"#hero\" class=\"hover:text-[var(--meade-honey)] transition-colors\" data-kid=\"5\">Experience</a>\n    <a href=\"#journey\" class=\"hover:text-[var(--meade-honey)] transition-colors\" data-kid=\"6\">Journey</a>\n    <a href=\"#projects\" class=\"hover:text-[var(--meade-honey)] transition-colors\" data-kid=\"7\">Showcase</a>\n    <a href=\"#swag\" class=\"hover:text-[var(--meade-honey)] transition-colors\" data-kid=\"8\">Vault</a>\n  </div>\n  <button class=\"font-syne font-bold text-xs uppercase tracking-widest text-white border border-white/20 px-6 py-3 hover:bg-white hover:text-black transition-all\" data-kid=\"9\">\n    Sign In\n  </button>\n</nav>\n\n\n<section id=\"hero\" class=\"min-h-screen flex items-center pt-24 px-12 overflow-hidden relative\" data-kid=\"10\">\n  <div class=\"container mx-auto grid grid-cols-12 gap-16 items-center\" data-kid=\"11\">\n    \n    <div class=\"col-span-12 lg:col-span-7 space-y-12\" data-kid=\"12\">\n      <div class=\"space-y-8\" data-kid=\"13\">\n        <div class=\"flex items-center gap-4\" data-kid=\"14\">\n          <span class=\"w-12 h-[1px] bg-[var(--nettle-green)]\" data-kid=\"15\"></span>\n          <span class=\"text-[var(--nettle-green)] text-[11px] font-black uppercase tracking-[0.4em]\" data-kid=\"16\">The Elite Protocol</span>\n        </div>\n        <h1 class=\"font-syne text-[clamp(4rem,9vw,7.5rem)] font-extrabold leading-[0.85] tracking-tighter\" data-kid=\"17\">\n          Hardened <br data-kid=\"18\">\n          <span class=\"text-[var(--meade-honey)]\" data-kid=\"19\">Grit.</span> <br data-kid=\"20\">\n          Success.\n        </h1>\n      </div>\n      \n      <p class=\"text-2xl text-[var(--cool-slate)]/70 max-w-xl leading-relaxed font-medium\" data-kid=\"21\">\n        Bridging the Tier-gap with high-frequency mentorship, national hackathons, and direct pipeline placement.\n      </p>\n\n      <div class=\"flex flex-wrap items-center gap-10 pt-6\" data-kid=\"22\">\n        <button class=\"metallic-sheen px-14 py-7 font-syne font-black text-sm uppercase tracking-[0.2em] shadow-[0_20px_50px_rgba(245,158,11,0.2)]\" data-kid=\"23\">\n          Join the Family\n        </button>\n        <button class=\"group flex items-center gap-4 font-syne font-black text-sm uppercase tracking-[0.2em] border-b-[3px] border-[var(--cool-slate)] pb-3 hover:border-[var(--meade-honey)] hover:text-[var(--meade-honey)] transition-all\" data-kid=\"24\">\n          View Projects\n          <i class=\"ti ti-arrow-up-right text-2xl group-hover:translate-x-1 group-hover:-translate-y-1 transition-transform\" data-kid=\"25\"></i>\n        </button>\n      </div>\n    </div>\n\n    \n    <div class=\"col-span-12 lg:col-span-5 relative\" data-kid=\"26\">\n      <div class=\"parallax-container relative w-full aspect-[4/5] flex items-center justify-center group/hero\" data-kid=\"27\">\n        \n        <div class=\"relative z-20 w-full h-full transform overflow-hidden rounded-[100px] border-4 border-white/20\" data-kid=\"28\">\n          <div class=\"absolute inset-0 bg-gradient-to-tr from-[var(--meade-honey)]/20 to-transparent z-10 mix-blend-overlay\" data-kid=\"29\"></div>\n          <img src=\"https://images.unsplash.com/photo-1758314896569-b3639ee707c4?auto=format&w=1400&q=90&fit=crop\" class=\"w-full h-full object-cover shadow-[0_80px_150px_-20px_rgba(0,0,0,0.3)] filter contrast-[1.1] brightness-[1.1]\" alt=\"3D Growth Construct\" id=\"hero-main-img\" data-kid=\"30\">\n        </div>\n\n        \n        <div class=\"absolute -top-12 -right-8 p-8 glass-card rounded-none shadow-[0_40px_80px_rgba(0,0,0,0.1)] border border-white/80 z-30 animate-float-slow\" data-kid=\"31\">\n           <i class=\"ti ti-crown text-[var(--meade-honey)] text-5xl mb-4 block\" data-kid=\"32\"></i>\n           <div class=\"font-syne font-black text-sm uppercase tracking-widest\" data-kid=\"33\">Rank #1</div>\n        </div>\n        \n        <div class=\"absolute -bottom-16 -left-12 p-10 glass-card rounded-none shadow-[0_40px_80px_rgba(0,0,0,0.1)] border border-white/80 z-30 animate-float-slow delay-500\" data-kid=\"34\">\n          <div class=\"font-syne font-black text-5xl text-[var(--nettle-green)] mb-2 tracking-tighter\" data-kid=\"35\">18K+</div>\n          <div class=\"text-[11px] font-black uppercase tracking-[0.2em] opacity-40\" data-kid=\"36\">Validated Builders</div>\n        </div>\n      </div>\n    </div>\n  </div>\n</section>\n\n\n<section id=\"journey\" class=\"py-40 relative bg-white\" data-kid=\"37\">\n  <div class=\"container mx-auto px-6 text-center max-w-4xl relative z-10\" data-kid=\"38\">\n    <div class=\"mb-32\" data-kid=\"39\">\n      <h2 class=\"font-syne text-5xl md:text-7xl font-extrabold tracking-tighter mb-8\" data-kid=\"40\">The Hardened Path</h2>\n      <p class=\"text-[var(--cool-slate)]/50 text-lg\" data-kid=\"41\">A precisely engineered trajectory from campus to the world's elite dev teams.</p>\n    </div>\n\n    \n    <div class=\"relative min-h-[900px]\" data-kid=\"42\">\n      <svg class=\"absolute top-0 left-1/2 -translate-x-1/2 w-full h-full pointer-events-none\" preserveAspectRatio=\"none\" data-kid=\"43\">\n        <path id=\"journey-guide\" d=\"M 500 0 C 500 200 100 200 100 450 C 100 700 900 700 900 900\" fill=\"none\" stroke=\"var(--nettle-green)\" stroke-width=\"0.75\" class=\"journey-path\" data-kid=\"44\"></path>\n      </svg>\n\n      \n      <div class=\"space-y-[120px]\" data-kid=\"45\">\n        \n        <div class=\"flex justify-start relative group\" data-kid=\"46\">\n          <div class=\"step-card glass-card p-10 max-w-sm text-left shadow-2xl transition-all duration-500 hover:scale-110 hover:-translate-y-4\" data-kid=\"47\">\n            <div class=\"font-syne font-black text-6xl text-[var(--meade-honey)]/20 mb-6\" data-kid=\"48\">01.</div>\n            <h3 class=\"font-syne text-2xl font-bold mb-4\" data-kid=\"49\">Forge Your ID</h3>\n            <p class=\"text-sm text-[var(--cool-slate)]/60 leading-relaxed\" data-kid=\"50\">Identity verification and Proof-of-Skill tagging. We evaluate your code, not your college tier.</p>\n          </div>\n        </div>\n\n        \n        <div class=\"flex justify-end relative group\" data-kid=\"51\">\n          <div class=\"step-card glass-card p-10 max-w-sm text-left shadow-2xl transition-all duration-500 hover:scale-110 hover:-translate-y-4\" data-kid=\"52\">\n            <div class=\"font-syne font-black text-6xl text-[var(--nettle-green)]/20 mb-6\" data-kid=\"53\">02.</div>\n            <h3 class=\"font-syne text-2xl font-bold mb-4\" data-kid=\"54\">Master Sprints</h3>\n            <p class=\"text-sm text-[var(--cool-slate)]/60 leading-relaxed\" data-kid=\"55\">Intensive 48-hour build cycles with direct code reviews from engineering leads at MAANG.</p>\n          </div>\n        </div>\n\n        \n        <div class=\"flex justify-start relative group\" data-kid=\"56\">\n          <div class=\"step-card glass-card p-10 max-w-sm text-left shadow-2xl transition-all duration-500 hover:scale-110 hover:-translate-y-4\" data-kid=\"57\">\n            <div class=\"font-syne font-black text-6xl text-[var(--meade-honey)]/20 mb-6\" data-kid=\"58\">03.</div>\n            <h3 class=\"font-syne text-2xl font-bold mb-4\" data-kid=\"59\">The Launch</h3>\n            <p class=\"text-sm text-[var(--cool-slate)]/60 leading-relaxed\" data-kid=\"60\">Direct placement pipeline into high-growth unicorns. Skip the standard resume filters.</p>\n          </div>\n        </div>\n      </div>\n    </div>\n  </div>\n</section>\n\n\n<section id=\"projects\" class=\"py-40 bg-[var(--cloud-white)]\" data-kid=\"61\">\n  <div class=\"container mx-auto px-12\" data-kid=\"62\">\n    <div class=\"flex flex-col md:flex-row justify-between items-end mb-24 gap-8\" data-kid=\"63\">\n      <div class=\"max-w-2xl\" data-kid=\"64\">\n        <h2 class=\"font-syne text-6xl font-extrabold tracking-tighter mb-8\" data-kid=\"65\">Bento Showcase</h2>\n        <p class=\"text-xl text-[var(--cool-slate)]/60 leading-relaxed\" data-kid=\"66\">Borderless innovation defined by depth. These are the projects setting new standards.</p>\n      </div>\n      <button class=\"font-syne font-bold text-xs uppercase tracking-[0.3em] bg-black text-white px-10 py-5 hover:bg-[var(--meade-honey)] transition-all\" data-kid=\"67\">\n        Submit Your Build\n      </button>\n    </div>\n\n    <div class=\"grid grid-cols-1 md:grid-cols-12 gap-16\" data-kid=\"68\">\n      \n      <div class=\"md:col-span-8 group\" data-kid=\"69\">\n        <div class=\"bg-white honey-shadow p-16 h-full flex flex-col justify-between hover:scale-[1.01] transition-shadow transition-transform duration-300\" data-kid=\"70\">\n          <div class=\"space-y-8\" data-kid=\"71\">\n            <div class=\"flex items-center gap-4\" data-kid=\"72\">\n              <span class=\"px-5 py-1.5 bg-[var(--meade-honey)] text-white text-[10px] font-black uppercase tracking-widest\" data-kid=\"73\">System Design</span>\n              <span class=\"text-[10px] font-black text-black/20 tracking-tighter\" data-kid=\"74\">BUILD NO. 0042</span>\n            </div>\n            <h3 class=\"font-syne text-5xl font-extrabold leading-[0.95]\" data-kid=\"75\">HydraIndex: <br data-kid=\"76\"> Distributed Ledger.</h3>\n            <p class=\"text-xl text-[var(--cool-slate)]/50 max-w-md leading-relaxed font-light\" data-kid=\"77\">Engineered for cold-start latency reduction in high-frequency serverless clusters.</p>\n          </div>\n          <div class=\"mt-16 overflow-hidden rounded-none border border-black/5\" data-kid=\"78\">\n            <img src=\"https://images.unsplash.com/photo-1551288049-bebda4e38f71?auto=format&w=1200&q=80&fit=crop\" class=\"w-full h-auto object-cover grayscale opacity-60 group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-1000\" alt=\"HydraIndex\" data-kid=\"79\">\n          </div>\n        </div>\n      </div>\n\n      \n      <div class=\"md:col-span-4 group\" data-kid=\"80\">\n        <div class=\"bg-white green-shadow p-12 h-full flex flex-col justify-between hover:scale-[1.02] transition-shadow transition-transform duration-300\" data-kid=\"81\">\n          <div class=\"space-y-6\" data-kid=\"82\">\n            <span class=\"px-5 py-1.5 bg-[var(--nettle-green)] text-white text-[10px] font-black uppercase tracking-widest\" data-kid=\"83\">Web Dev</span>\n            <h3 class=\"font-syne text-3xl font-black\" data-kid=\"84\">DevClans</h3>\n            <p class=\"text-base text-[var(--cool-slate)]/40 leading-relaxed font-medium\" data-kid=\"85\">Global hackathon orchestration for elite team formation.</p>\n          </div>\n          <div class=\"pt-10 border-t border-black/5 flex justify-between items-center\" data-kid=\"86\">\n            <span class=\"font-syne font-black text-xs tracking-widest\" data-kid=\"87\">EST. 2026</span>\n            <i class=\"ti ti-arrow-up-right text-3xl text-[var(--nettle-green)] group-hover:translate-x-1 group-hover:-translate-y-1 transition-transform\" data-kid=\"88\"></i>\n          </div>\n        </div>\n      </div>\n\n      \n      <div class=\"md:col-span-4 group\" data-kid=\"89\">\n        <div class=\"bg-white honey-shadow p-12 h-full flex flex-col justify-between hover:scale-[1.02] transition-shadow transition-transform duration-300\" data-kid=\"90\">\n          <div class=\"space-y-6\" data-kid=\"91\">\n            <span class=\"px-5 py-1.5 bg-[var(--meade-honey)] text-white text-[10px] font-black uppercase tracking-widest\" data-kid=\"92\">Fintech</span>\n            <h3 class=\"font-syne text-3xl font-black text-[var(--meade-honey)]\" data-kid=\"93\">SolPay</h3>\n            <p class=\"text-base text-[var(--cool-slate)]/40 leading-relaxed font-medium\" data-kid=\"94\">Merchant-ready USDC rail for decentralized commerce.</p>\n          </div>\n          <div class=\"pt-10 border-t border-black/5 flex justify-between items-center\" data-kid=\"95\">\n            <span class=\"font-syne font-black text-xs tracking-widest\" data-kid=\"96\">PROTOCOL V1</span>\n            <i class=\"ti ti-brand-solana text-3xl text-[var(--meade-honey)]\" data-kid=\"97\"></i>\n          </div>\n        </div>\n      </div>\n\n      \n      <div class=\"md:col-span-8 group\" data-kid=\"98\">\n        <div class=\"bg-white green-shadow p-12 h-full flex flex-col items-center justify-center text-center space-y-10 hover:scale-[1.01] transition-shadow transition-transform duration-300\" data-kid=\"99\">\n          <div class=\"w-32 h-32 bg-[var(--cloud-white)] border-2 border-dashed border-[var(--nettle-green)]/20 rounded-full flex items-center justify-center group-hover:border-[var(--nettle-green)] transition-colors\" data-kid=\"100\">\n            <i class=\"ti ti-plus text-5xl text-[var(--nettle-green)]\" data-kid=\"101\"></i>\n          </div>\n          <div class=\"max-w-md\" data-kid=\"102\">\n            <h3 class=\"font-syne text-5xl font-black mb-6\" data-kid=\"103\">Your Build.</h3>\n            <p class=\"text-lg text-[var(--cool-slate)]/40 font-medium\" data-kid=\"104\">Submit to the showcase. Get validated by recruiters from MAANG and global unicorns.</p>\n          </div>\n        </div>\n      </div>\n    </div>\n  </div>\n</section>\n\n\n<section id=\"swag\" class=\"py-40 bg-white overflow-hidden relative\" data-kid=\"105\">\n  <div class=\"container mx-auto px-6 text-center mb-24\" data-kid=\"106\">\n    <h2 class=\"font-syne text-6xl font-extrabold tracking-tighter mb-8\" data-kid=\"107\">The Hardened Vault</h2>\n    <p class=\"text-[var(--cool-slate)]/50\" data-kid=\"108\">Convert your VX Coins into physical proof of your legacy.</p>\n  </div>\n\n  <div class=\"flex items-center justify-center carousel-wrapper relative h-[650px] w-full\" data-kid=\"109\">\n    <div id=\"swag-carousel\" class=\"flex items-center gap-16 px-4 cursor-grab active:cursor-grabbing\" data-kid=\"110\">\n      \n      <div class=\"carousel-item flex-shrink-0 w-[380px]\" data-kid=\"111\">\n        <div class=\"bg-white p-12 shadow-[0_60px_120px_-20px_rgba(0,0,0,0.1)] border border-black/5 text-center\" data-kid=\"112\">\n          <div class=\"aspect-square bg-[var(--cloud-white)] mb-12 flex items-center justify-center rounded-none border border-black/5\" data-kid=\"113\">\n            <i class=\"ti ti-shirt text-9xl text-[var(--cool-slate)] opacity-20\" data-kid=\"114\"></i>\n          </div>\n          <h3 class=\"font-syne text-3xl font-black mb-4\" data-kid=\"115\">Elite Hoodie</h3>\n          <p class=\"text-base text-[var(--cool-slate)]/40 mb-10 px-4 font-medium leading-relaxed\" data-kid=\"116\">Heavyweight cotton. Hand-stitched gold protocol badge.</p>\n          <div class=\"inline-block px-8 py-3 bg-[var(--meade-honey)] text-white font-black tracking-[0.2em] text-[10px] uppercase shadow-lg\" data-kid=\"117\">2,500 VX COINS</div>\n        </div>\n      </div>\n\n      \n      <div class=\"carousel-item active flex-shrink-0 w-[380px]\" data-kid=\"118\">\n        <div class=\"bg-white p-12 shadow-[0_60px_120px_-20px_rgba(0,0,0,0.1)] border border-black/5 text-center\" data-kid=\"119\">\n          <div class=\"aspect-square bg-[var(--cloud-white)] mb-12 flex items-center justify-center rounded-none border border-black/5\" data-kid=\"120\">\n            <i class=\"ti ti-backpack text-9xl text-[var(--nettle-green)] opacity-40\" data-kid=\"121\"></i>\n          </div>\n          <h3 class=\"font-syne text-3xl font-black mb-4\" data-kid=\"122\">Nomad Techpack</h3>\n          <p class=\"text-base text-[var(--cool-slate)]/40 mb-10 px-4 font-medium leading-relaxed\" data-kid=\"123\">Ballistic nylon. Isolated laptop vault with RFID shielding.</p>\n          <div class=\"inline-block px-8 py-3 bg-[var(--nettle-green)] text-white font-black tracking-[0.2em] text-[10px] uppercase shadow-lg\" data-kid=\"124\">5,000 VX COINS</div>\n        </div>\n      </div>\n\n      \n      <div class=\"carousel-item flex-shrink-0 w-[380px]\" data-kid=\"125\">\n        <div class=\"bg-white p-12 shadow-[0_60px_120px_-20px_rgba(0,0,0,0.1)] border border-black/5 text-center\" data-kid=\"126\">\n          <div class=\"aspect-square bg-[var(--cloud-white)] mb-12 flex items-center justify-center rounded-none border border-black/5\" data-kid=\"127\">\n            <i class=\"ti ti-mug text-9xl text-[var(--meade-honey)] opacity-40\" data-kid=\"128\"></i>\n          </div>\n          <h3 class=\"font-syne text-3xl font-black mb-4\" data-kid=\"129\">Builder's Mug</h3>\n          <p class=\"text-base text-[var(--cool-slate)]/40 mb-10 px-4 font-medium leading-relaxed\" data-kid=\"130\">Matte double-walled ceramic. Keeps heat for 12 hours.</p>\n          <div class=\"inline-block px-8 py-3 bg-[var(--meade-honey)] text-white font-black tracking-[0.2em] text-[10px] uppercase shadow-lg\" data-kid=\"131\">1,200 VX COINS</div>\n        </div>\n      </div>\n\n      \n      <div class=\"carousel-item flex-shrink-0 w-[380px]\" data-kid=\"132\">\n        <div class=\"bg-white p-12 shadow-[0_60px_120px_-20px_rgba(0,0,0,0.1)] border border-black/5 text-center\" data-kid=\"133\">\n          <div class=\"aspect-square bg-[var(--cloud-white)] mb-12 flex items-center justify-center rounded-none border border-black/5\" data-kid=\"134\">\n            <i class=\"ti ti-bottle text-9xl text-[var(--cool-slate)] opacity-20\" data-kid=\"135\"></i>\n          </div>\n          <h3 class=\"font-syne text-3xl font-black mb-4\" data-kid=\"136\">Hardened Flask</h3>\n          <p class=\"text-base text-[var(--cool-slate)]/40 mb-10 px-4 font-medium leading-relaxed\" data-kid=\"137\">Vacuum-sealed titanium. Titanium gold finish.</p>\n          <div class=\"inline-block px-8 py-3 bg-[var(--meade-honey)] text-white font-black tracking-[0.2em] text-[10px] uppercase shadow-lg\" data-kid=\"138\">3,500 VX COINS</div>\n        </div>\n      </div>\n    </div>\n  </div>\n\n  \n  <div class=\"flex justify-center gap-12 mt-20\" data-kid=\"139\">\n    <button id=\"swag-prev\" class=\"p-6 border border-black/10 hover:border-black transition-all\" data-kid=\"140\">\n      <i class=\"ti ti-chevron-left text-2xl\" data-kid=\"141\"></i>\n    </button>\n    <button id=\"swag-next\" class=\"p-6 border border-black/10 hover:border-black transition-all\" data-kid=\"142\">\n      <i class=\"ti ti-chevron-right text-2xl\" data-kid=\"143\"></i>\n    </button>\n  </div>\n</section>\n\n\n<section class=\"py-60 bg-black text-white text-center relative overflow-hidden\" data-kid=\"144\">\n  \n  <div class=\"absolute inset-0 bg-radial-gradient from-[var(--meade-honey)]/20 to-transparent blur-[150px] opacity-30\" data-kid=\"145\"></div>\n  \n  <div class=\"container mx-auto px-6 relative z-10 space-y-16\" data-kid=\"146\">\n    <div class=\"space-y-6\" data-kid=\"147\">\n      <h2 class=\"font-syne text-6xl md:text-8xl font-black tracking-tighter\" data-kid=\"148\">Forged From <br data-kid=\"149\"> <span class=\"text-[var(--meade-honey)]\" data-kid=\"150\">Ambition.</span></h2>\n      <p class=\"text-xl text-white/40 max-w-2xl mx-auto leading-relaxed\" data-kid=\"151\">Your campus tag doesn't define you. Your build does. Join 15,000+ engineers from Tier-2 and Tier-3 colleges across India.</p>\n    </div>\n    \n    <div class=\"flex flex-col md:flex-row items-center justify-center gap-8\" data-kid=\"152\">\n      <button class=\"metallic-sheen px-16 py-8 font-syne font-black text-lg tracking-[0.2em] uppercase shadow-2xl\" data-kid=\"153\">\n        Claim Your Future\n      </button>\n      <button class=\"px-12 py-8 font-syne font-bold text-sm tracking-[0.2em] uppercase border border-white/20 hover:bg-white hover:text-black transition-all\" data-kid=\"154\">\n        Book 1:1 Session\n      </button>\n    </div>\n  </div>\n</section>\n\n\n<footer class=\"py-20 bg-black text-white/30 border-t border-white/5\" data-kid=\"155\">\n  <div class=\"container mx-auto px-12 grid grid-cols-12 gap-12\" data-kid=\"156\">\n    <div class=\"col-span-12 md:col-span-6 space-y-6\" data-kid=\"157\">\n      <div class=\"font-syne font-black text-2xl tracking-tighter text-white\" data-kid=\"158\">VELONX</div>\n      <p class=\"text-xs uppercase tracking-widest leading-loose\" data-kid=\"159\">The premier hardened ecosystem <br data-kid=\"160\"> for the next generation of engineers.</p>\n    </div>\n    <div class=\"col-span-6 md:col-span-3 space-y-6\" data-kid=\"161\">\n      <h4 class=\"text-white font-syne font-bold text-xs uppercase tracking-widest\" data-kid=\"162\">Resources</h4>\n      <div class=\"flex flex-col gap-4 text-xs font-medium\" data-kid=\"163\">\n        <a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"164\">Documentation</a>\n        <a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"165\">University Hub</a>\n        <a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"166\">Brand Assets</a>\n      </div>\n    </div>\n    <div class=\"col-span-6 md:col-span-3 space-y-6\" data-kid=\"167\">\n      <h4 class=\"text-white font-syne font-bold text-xs uppercase tracking-widest\" data-kid=\"168\">Connect</h4>\n      <div class=\"flex flex-col gap-4 text-xs font-medium\" data-kid=\"169\">\n        <a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"170\">X / Twitter</a>\n        <a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"171\">LinkedIn</a>\n        <a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"172\">Discord</a>\n      </div>\n    </div>\n    <div class=\"col-span-12 pt-20 border-t border-white/5 flex flex-col md:flex-row justify-between items-center gap-8 text-[10px] uppercase tracking-widest\" data-kid=\"173\">\n      <p data-kid=\"174\">&copy; 2026 Velonx Engineering Platform. All Rights Reserved.</p>\n      <div class=\"flex gap-12\" data-kid=\"175\">\n        <a href=\"#\" class=\"hover:text-white\" data-kid=\"176\">Privacy Policy</a>\n        <a href=\"#\" class=\"hover:text-white\" data-kid=\"177\">Terms of Protocol</a>\n      </div>\n    </div>\n  </div>\n</footer>\n\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"178\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"179\"></script>\n<script type=\"module\" data-kid=\"180\">\n  import Lenis from \"https://esm.sh/lenis@1\"\n  const lenis = new Lenis()\n  function raf(time) {\n    lenis.raf(time)\n    requestAnimationFrame(raf)\n  }\n  requestAnimationFrame(raf)\n</script>\n\n<script data-kid=\"181\">\n  gsap.registerPlugin(ScrollTrigger);\n\n  // Hero Parallax\n  gsap.to(\"#hero-main-img\", {\n    y: -100,\n    rotate: -5,\n    scrollTrigger: {\n      trigger: \"#hero\",\n      start: \"top top\",\n      end: \"bottom top\",\n      scrub: 1\n    }\n  });\n\n  // Journey Path Animation\n  gsap.to(\".journey-path\", {\n    strokeDashoffset: 0,\n    scrollTrigger: {\n      trigger: \"#journey\",\n      start: \"top 20%\",\n      end: \"bottom bottom\",\n      scrub: 2\n    }\n  });\n\n  // Swag Carousel Logic\n  const items = document.querySelectorAll('.carousel-item');\n  const prevBtn = document.getElementById('swag-prev');\n  const nextBtn = document.getElementById('swag-next');\n  const carousel = document.getElementById('swag-carousel');\n  let currentIndex = 1;\n\n  function updateCarousel() {\n    items.forEach((item, index) => {\n      item.classList.remove('active');\n      if (index === currentIndex) {\n        item.classList.add('active');\n        // Add subtle gold glow to active card\n        gsap.to(item.children[0], { boxShadow: \"0 80px 160px -40px rgba(245, 158, 11, 0.25)\", duration: 0.8 });\n      } else {\n        gsap.to(item.children[0], { boxShadow: \"0 60px 120px -20px rgba(0,0,0,0.1)\", duration: 0.8 });\n      }\n    });\n    \n    const itemWidth = items[0].offsetWidth;\n    const gap = 64;\n    const totalItemWidth = itemWidth + gap;\n    const containerWidth = carousel.parentElement.offsetWidth;\n    const centerOffset = (containerWidth / 2) - (itemWidth / 2);\n    \n    const scrollAmount = - (currentIndex * totalItemWidth) + centerOffset;\n    \n    gsap.to(carousel, {\n      x: scrollAmount,\n      duration: 1.5,\n      ease: \"expo.out\"\n    });\n  }\n\n  nextBtn.addEventListener('click', () => {\n    if (currentIndex < items.length - 1) {\n      currentIndex++;\n      updateCarousel();\n    } else {\n      currentIndex = 0;\n      updateCarousel();\n    }\n  });\n\n  prevBtn.addEventListener('click', () => {\n    if (currentIndex > 0) {\n      currentIndex--;\n      updateCarousel();\n    } else {\n      currentIndex = items.length - 1;\n      updateCarousel();\n    }\n  });\n\n  // Scroll Reveal for Bento Cards\n  gsap.from(\".honey-shadow, .green-shadow\", {\n    y: 100,\n    opacity: 0,\n    stagger: 0.2,\n    duration: 1,\n    ease: \"power3.out\",\n    scrollTrigger: {\n      trigger: \"#projects\",\n      start: \"top 80%\"\n    }\n  });\n\n  // Initial center\n  window.addEventListener('load', () => {\n    setTimeout(updateCarousel, 100);\n  });\n\n  // Float Animation for elements\n  gsap.to(\".animate-float-slow\", {\n    y: 20,\n    duration: 3,\n    repeat: -1,\n    yoyo: true,\n    ease: \"power1.inOut\",\n    stagger: 0.5\n  });\n</script>\n\n<link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css\" data-kid=\"182\">\n<link rel=\"stylesheet\" href=\"https://unpkg.com/lenis@1/dist/lenis.css\" data-kid=\"183\">\n",
