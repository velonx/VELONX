      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:wght@800&family=DM+Sans:wght@400;500;700&display=swap');\n\n  :root {\n    --tabasco: #E03A3A;\n    --nectarine: #FF8A5B;\n    --cream: #FFFDF8;\n    --sepia: #2D1F1A;\n    --fame-gold: #F7C844;\n  }\n\n  body {\n    background-color: var(--cream);\n    color: var(--sepia);\n    font-family: 'DM Sans', sans-serif;\n    margin: 0;\n    padding: 0;\n    overflow-x: hidden;\n  }\n\n  .font-heading {\n    font-family: 'Bricolage Grotesque', sans-serif;\n  }\n\n  /* Custom Noise Overlay */\n  .noise-overlay {\n    position: fixed;\n    inset: 0;\n    background-image: url(\"data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E\");\n    opacity: 0.02;\n    pointer-events: none;\n    z-index: 9999;\n  }\n\n  .text-gradient {\n    background: linear-gradient(135deg, var(--tabasco) 0%, var(--nectarine) 100%);\n    -webkit-background-clip: text;\n    -webkit-text-fill-color: transparent;\n    background-clip: text;\n  }\n\n  .glass-card {\n    background: rgba(255, 255, 255, 0.4);\n    backdrop-filter: blur(12px);\n    -webkit-backdrop-filter: blur(12px);\n    border: 1px solid rgba(255, 255, 255, 0.5);\n    border-radius: 24px;\n  }\n\n  .frosted-glass {\n    background: rgba(255, 255, 255, 0.15);\n    backdrop-filter: blur(25px);\n    -webkit-backdrop-filter: blur(25px);\n    border: 1px solid rgba(255, 255, 255, 0.3);\n  }\n\n  .wide-orange-shadow {\n    box-shadow: 0 40px 80px -10px rgba(224, 58, 58, 0.25), 0 20px 40px -5px rgba(255, 138, 91, 0.4);\n  }\n\n  .btn-primary {\n    background-color: var(--tabasco);\n    color: white;\n    padding: 1rem 2.5rem;\n    border-radius: 9999px;\n    font-weight: 700;\n    transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);\n    border: none;\n    cursor: pointer;\n  }\n\n  .btn-primary:hover {\n    transform: translateY(-4px);\n    box-shadow: 0 15px 30px rgba(224, 58, 58, 0.3);\n  }\n\n  .btn-secondary {\n    background: transparent;\n    color: var(--sepia);\n    padding: 1rem 2.5rem;\n    border-radius: 9999px;\n    font-weight: 700;\n    border: 2px solid var(--sepia);\n    cursor: pointer;\n    transition: all 0.3s ease;\n  }\n\n  .btn-secondary:hover {\n    background-color: var(--sepia);\n    color: white;\n  }\n\n  .journey-dot {\n    width: 72px;\n    height: 72px;\n    border-radius: 50%;\n    background: white;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    box-shadow: 0 15px 30px rgba(255, 138, 91, 0.3);\n    z-index: 10;\n    position: relative;\n    border: 3px solid var(--nectarine);\n    transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);\n  }\n\n  .journey-dot:hover {\n    transform: scale(1.15) rotate(5deg);\n  }\n\n  .bento-grid {\n    display: grid;\n    grid-template-columns: repeat(3, 1fr);\n    grid-auto-rows: minmax(320px, auto);\n    gap: 24px;\n  }\n\n  @media (max-width: 1024px) {\n    .bento-grid {\n      grid-template-columns: 1fr 1fr;\n    }\n  }\n\n  @media (max-width: 768px) {\n    .bento-grid {\n      grid-template-columns: 1fr;\n    }\n  }\n\n  .bento-primary {\n    grid-column: span 2;\n    grid-row: span 2;\n  }\n\n  .bento-card {\n    border-radius: 32px;\n    padding: 2.5rem;\n    position: relative;\n    overflow: hidden;\n    border: 1px solid rgba(255, 255, 255, 0.15);\n    backdrop-filter: blur(10px);\n    box-shadow: 0 10px 40px -10px rgba(0, 0, 0, 0.3);\n  }\n\n  .bento-primary {\n    border: 1px solid rgba(255, 255, 255, 0.25);\n  }\n\n  /* SVG Path Glow */\n  .svg-glow {\n    filter: drop-shadow(0 0 15px rgba(255, 138, 91, 0.8));\n    stroke-dasharray: 1;\n    stroke-dashoffset: 1;\n  }\n\n  .testimonial-card {\n    will-change: transform, opacity;\n  }\n\n  /* Utility classes for layout */\n  .section-padding {\n    padding: 120px 0;\n  }\n\n  .container-custom {\n    max-width: 1280px;\n    margin: 0 auto;\n    padding: 0 24px;\n  }\n\n</style>\n\n<div class=\"noise-overlay\" data-kid=\"1\"></div>\n\n\n<section class=\"min-h-screen relative flex items-center overflow-hidden\" data-kid=\"2\">\n  <div class=\"container-custom grid grid-cols-1 lg:grid-cols-2 gap-16 items-center z-10\" data-kid=\"3\">\n    <div class=\"hero-content\" data-kid=\"4\">\n      <div class=\"inline-flex items-center gap-2 bg-[#FF8A5B]/10 px-4 py-2 rounded-full mb-8\" data-kid=\"5\">\n        <span class=\"w-2 h-2 rounded-full bg-[#E03A3A] animate-ping\" data-kid=\"6\"></span>\n        <span class=\"text-xs font-bold uppercase tracking-widest text-[#E03A3A]\" data-kid=\"7\">India's #1 Student Tech Platform</span>\n      </div>\n      <h1 class=\"font-heading text-7xl md:text-[100px] leading-[0.85] tracking-tighter mb-10 hero-title\" data-kid=\"8\">\n        Your Future<br data-kid=\"9\">\n        Has No<br data-kid=\"10\">\n        <span class=\"text-gradient\" data-kid=\"11\">Limits.</span>\n      </h1>\n      <p class=\"text-xl max-w-lg opacity-80 mb-12 leading-relaxed\" data-kid=\"12\">\n        Velonx is the career launchpad for Tier-2 & 3 college students. Build real projects, get elite mentorship, and land high-growth roles.\n      </p>\n      <div class=\"flex flex-wrap gap-6\" data-kid=\"13\">\n        <button class=\"btn-primary text-lg\" data-kid=\"14\">Join the Elite Clan</button>\n        <button class=\"btn-secondary text-lg\" data-kid=\"15\">Explore the Hub</button>\n      </div>\n    </div>\n\n    <div class=\"relative hero-visual h-[600px] flex items-center justify-center\" data-kid=\"16\">\n      \n      <div class=\"absolute w-[120%] h-[120%] bg-gradient-to-br from-[#FF8A5B]/20 to-transparent rounded-full blur-3xl -z-10 animate-pulse\" data-kid=\"17\"></div>\n      \n      \n      <div class=\"relative w-full max-w-md aspect-square rounded-3xl overflow-hidden glass-card shadow-2xl p-2 border-white/50\" data-kid=\"18\">\n         <img src=\"https://images.pexels.com/photos/5940844/pexels-photo-5940844.jpeg?auto=compress&cs=tinysrgb&w=800&q=80\" alt=\"Students\" class=\"w-full h-full object-cover rounded-2xl\" data-kid=\"19\">\n      </div>\n\n      \n      \n      <div class=\"absolute -top-10 -right-4 glass-card p-6 wide-orange-shadow w-72 floating-card-1 border-white\" data-kid=\"20\">\n        <div class=\"flex items-center gap-4\" data-kid=\"21\">\n          <div class=\"w-14 h-14 bg-green-500/10 rounded-2xl flex items-center justify-center text-3xl\" data-kid=\"22\">🎉</div>\n          <div data-kid=\"23\">\n            <div class=\"text-[10px] font-bold opacity-50 uppercase tracking-[0.2em] mb-1\" data-kid=\"24\">Placement Alert</div>\n            <div class=\"font-bold text-xl text-[#E03A3A] leading-tight\" data-kid=\"25\">Offer Received!</div>\n            <div class=\"text-sm font-medium opacity-70\" data-kid=\"26\">₹33 LPA • Razorpay</div>\n          </div>\n        </div>\n      </div>\n\n      \n      <div class=\"absolute bottom-4 -left-10 glass-card p-6 wide-orange-shadow w-72 floating-card-2 border-white\" data-kid=\"27\">\n        <div class=\"flex items-center gap-4\" data-kid=\"28\">\n          <div class=\"w-14 h-14 bg-yellow-500/10 rounded-2xl flex items-center justify-center text-3xl\" data-kid=\"29\">🏆</div>\n          <div data-kid=\"30\">\n            <div class=\"text-[10px] font-bold opacity-50 uppercase tracking-[0.2em] mb-1\" data-kid=\"31\">Hackathon Win</div>\n            <div class=\"font-bold text-xl text-[#FF8A5B] leading-tight\" data-kid=\"32\">#1 Winner</div>\n            <div class=\"text-sm font-medium opacity-70\" data-kid=\"33\">Solana Builder Sprint</div>\n          </div>\n        </div>\n      </div>\n      \n      \n      <div class=\"absolute bottom-40 -right-12 glass-card p-4 wide-orange-shadow floating-card-3 border-white\" data-kid=\"34\">\n        <div class=\"flex items-center gap-3\" data-kid=\"35\">\n          <div class=\"w-8 h-8 bg-blue-500 rounded-full flex items-center justify-center text-white text-xs font-bold\" data-kid=\"36\">JS</div>\n          <span class=\"font-bold text-sm\" data-kid=\"37\">Fullstack Verified</span>\n        </div>\n      </div>\n    </div>\n  </div>\n</section>\n\n\n<section class=\"section-padding relative\" data-kid=\"38\">\n  <div class=\"container-custom\" data-kid=\"39\">\n    <div class=\"text-center mb-24\" data-kid=\"40\">\n      <h2 class=\"font-heading text-6xl mb-6\" data-kid=\"41\">The Journey to <span class=\"text-gradient\" data-kid=\"42\">Impact</span></h2>\n      <p class=\"text-lg opacity-70 max-w-xl mx-auto\" data-kid=\"43\">From a raw student to a industry-ready builder. Here's how Velonx accelerates your growth.</p>\n    </div>\n\n    <div class=\"relative py-20\" data-kid=\"44\">\n      \n      <svg class=\"absolute inset-0 w-full h-full pointer-events-none\" viewBox=\"0 0 1200 1200\" fill=\"none\" preserveAspectRatio=\"none\" data-kid=\"45\">\n        <path id=\"journeyPath\" d=\"M600 0 C600 200 200 300 200 500 C200 700 1000 800 1000 1000 C1000 1150 600 1200 600 1400\" stroke=\"var(--nectarine)\" stroke-width=\"16\" stroke-linecap=\"round\" class=\"svg-glow\" data-kid=\"46\"></path>\n      </svg>\n\n      <div class=\"space-y-48\" data-kid=\"47\">\n        \n        <div class=\"flex items-center justify-center gap-12 journey-item\" data-kid=\"48\">\n          <div class=\"w-1/2 text-right\" data-kid=\"49\">\n             <h3 class=\"font-heading text-4xl mb-4\" data-kid=\"50\">Create Profile</h3>\n             <p class=\"opacity-70 max-w-sm ml-auto\" data-kid=\"51\">Your builder identity is more than a resume. Show off your stacks, GitHub velocity, and community standing.</p>\n          </div>\n          <div class=\"journey-dot\" data-kid=\"52\">\n            <span class=\"text-3xl\" data-kid=\"53\">👤</span>\n          </div>\n          <div class=\"w-1/2\" data-kid=\"54\"></div>\n        </div>\n\n        \n        <div class=\"flex items-center justify-center gap-12 journey-item flex-row-reverse\" data-kid=\"55\">\n          <div class=\"w-1/2 text-left\" data-kid=\"56\">\n             <h3 class=\"font-heading text-4xl mb-4\" data-kid=\"57\">Build & Ship</h3>\n             <p class=\"opacity-70 max-w-sm mr-auto\" data-kid=\"58\">Proof of work is the ultimate currency. Build high-quality open-source products used by real users in the hub.</p>\n          </div>\n          <div class=\"journey-dot\" data-kid=\"59\">\n            <span class=\"text-3xl\" data-kid=\"60\">🚀</span>\n          </div>\n          <div class=\"w-1/2\" data-kid=\"61\"></div>\n        </div>\n\n        \n        <div class=\"flex items-center justify-center gap-12 journey-item\" data-kid=\"62\">\n          <div class=\"w-1/2 text-right\" data-kid=\"63\">\n             <h3 class=\"font-heading text-4xl mb-4\" data-kid=\"64\">Get Mentored</h3>\n             <p class=\"opacity-70 max-w-sm ml-auto\" data-kid=\"65\">1:1 sessions with industry leads from MAANG & high-growth startups to fix your roadmap and code quality.</p>\n          </div>\n          <div class=\"journey-dot\" data-kid=\"66\">\n            <span class=\"text-3xl\" data-kid=\"67\">💬</span>\n          </div>\n          <div class=\"w-1/2\" data-kid=\"68\"></div>\n        </div>\n\n        \n        <div class=\"flex items-center justify-center gap-12 journey-item flex-row-reverse\" data-kid=\"69\">\n          <div class=\"w-1/2 text-left\" data-kid=\"70\">\n             <h3 class=\"font-heading text-4xl mb-4\" data-kid=\"71\">Get Placed</h3>\n             <p class=\"opacity-70 max-w-sm mr-auto\" data-kid=\"72\">Land elite roles via our skill-first recruiting pipeline. Your tier doesn't matter, your skills do.</p>\n          </div>\n          <div class=\"journey-dot\" data-kid=\"73\">\n            <span class=\"text-3xl\" data-kid=\"74\">💼</span>\n          </div>\n          <div class=\"w-1/2\" data-kid=\"75\"></div>\n        </div>\n      </div>\n    </div>\n  </div>\n</section>\n\n\n<section class=\"section-padding bg-[#2D1F1A] text-white\" data-kid=\"76\">\n  <div class=\"container-custom\" data-kid=\"77\">\n    <div class=\"flex flex-col md:flex-row justify-between items-end mb-16 gap-8\" data-kid=\"78\">\n      <div class=\"max-w-xl\" data-kid=\"79\">\n        <span class=\"text-[#FF8A5B] font-bold uppercase tracking-widest text-sm mb-4 block\" data-kid=\"80\">Proof of Work Hub</span>\n        <h2 class=\"font-heading text-6xl leading-tight\" data-kid=\"81\">Student-Built <br data-kid=\"82\">Products.</h2>\n      </div>\n      <p class=\"text-lg opacity-60 max-w-md\" data-kid=\"83\">Our community builds products that actually function. Check out the latest top-voted student creations.</p>\n    </div>\n\n    <div class=\"bento-grid\" data-kid=\"84\">\n      \n      <div class=\"bento-card bento-primary frosted-glass group\" data-kid=\"85\">\n        <img src=\"https://images.unsplash.com/photo-1669023414162-8b0573b9c6b2?auto=format&w=1200&q=80&fit=crop\" class=\"absolute inset-0 w-full h-full object-cover opacity-20 group-hover:scale-110 transition-transform duration-700\" alt=\"DevClans\" data-kid=\"86\">\n        <div class=\"relative z-10 h-full flex flex-col justify-end\" data-kid=\"87\">\n          <div class=\"flex gap-2 mb-6\" data-kid=\"88\">\n            <span class=\"bg-white/10 px-3 py-1 rounded-full text-xs font-bold border border-white/20\" data-kid=\"89\">WEB3</span>\n            <span class=\"bg-white/10 px-3 py-1 rounded-full text-xs font-bold border border-white/20\" data-kid=\"90\">REAL-TIME</span>\n          </div>\n          <h3 class=\"font-heading text-5xl mb-6\" data-kid=\"91\">DevClans — <br data-kid=\"92\">Teammate Finder</h3>\n          <p class=\"text-lg opacity-70 max-w-lg mb-8\" data-kid=\"93\">A massive workspace for developers to find hackathon team members globally based on stack compatibility.</p>\n          <div class=\"flex items-center gap-4\" data-kid=\"94\">\n            <button class=\"bg-white text-[#2D1F1A] px-6 py-3 rounded-full font-bold\" data-kid=\"95\">View Project</button>\n            <div class=\"flex -space-x-2\" data-kid=\"96\">\n              <img src=\"https://i.pravatar.cc/100?u=1\" class=\"w-8 h-8 rounded-full border-2 border-[#2D1F1A]\" alt=\"A\" data-kid=\"97\">\n              <img src=\"https://i.pravatar.cc/100?u=2\" class=\"w-8 h-8 rounded-full border-2 border-[#2D1F1A]\" alt=\"B\" data-kid=\"98\">\n              <img src=\"https://i.pravatar.cc/100?u=3\" class=\"w-8 h-8 rounded-full border-2 border-[#2D1F1A]\" alt=\"C\" data-kid=\"99\">\n            </div>\n            <span class=\"text-sm opacity-50\" data-kid=\"100\">+42 contributors</span>\n          </div>\n        </div>\n      </div>\n\n      \n      <div class=\"bento-card frosted-glass group\" data-kid=\"101\">\n        <img src=\"https://images.unsplash.com/photo-1671519821564-ced7e41ee7ae?auto=format&w=800&q=80&fit=crop\" class=\"absolute inset-0 w-full h-full object-cover opacity-10 group-hover:scale-110 transition-transform duration-700\" alt=\"SolPay\" data-kid=\"102\">\n        <div class=\"relative z-10\" data-kid=\"103\">\n          <div class=\"w-16 h-16 bg-[#FF8A5B] rounded-2xl mb-8 flex items-center justify-center text-3xl\" data-kid=\"104\">🔗</div>\n          <h3 class=\"font-heading text-3xl mb-4\" data-kid=\"105\">SolPay SDK</h3>\n          <p class=\"opacity-60 text-sm mb-8 leading-relaxed\" data-kid=\"106\">Minimalist crypto payments widget for modern merchants to accept instant USDC on Solana.</p>\n          <button class=\"text-white font-bold border-b-2 border-[#FF8A5B] pb-1 hover:text-[#FF8A5B] transition-colors\" data-kid=\"107\">Explore Docs</button>\n        </div>\n      </div>\n\n      \n      <div class=\"bento-card frosted-glass group\" data-kid=\"108\">\n        <img src=\"https://images.unsplash.com/photo-1639322537228-f710d846310a?auto=format&w=800&q=80&fit=crop\" class=\"absolute inset-0 w-full h-full object-cover opacity-10 group-hover:scale-110 transition-transform duration-700\" alt=\"EduChain\" data-kid=\"109\">\n        <div class=\"relative z-10\" data-kid=\"110\">\n          <div class=\"w-16 h-16 bg-[#E03A3A] rounded-2xl mb-8 flex items-center justify-center text-3xl\" data-kid=\"111\">🛡️</div>\n          <h3 class=\"font-heading text-3xl mb-4\" data-kid=\"112\">EduChain</h3>\n          <p class=\"opacity-60 text-sm mb-8 leading-relaxed\" data-kid=\"113\">Verifiable college degree transcripts on the blockchain to eliminate credential fraud.</p>\n          <button class=\"text-white font-bold border-b-2 border-[#E03A3A] pb-1 hover:text-[#E03A3A] transition-colors\" data-kid=\"114\">See the Repo</button>\n        </div>\n      </div>\n    </div>\n  </div>\n</section>\n\n\n<section class=\"section-padding overflow-hidden\" data-kid=\"115\">\n  <div class=\"container-custom\" data-kid=\"116\">\n    <div class=\"text-center mb-24\" data-kid=\"117\">\n      <span class=\"text-[#E03A3A] font-bold uppercase tracking-widest text-sm mb-4 block\" data-kid=\"118\">Fame & Success</span>\n      <h2 class=\"font-heading text-6xl mb-6\" data-kid=\"119\">Built by <span class=\"text-gradient\" data-kid=\"120\">Real Students.</span></h2>\n    </div>\n\n    <div class=\"relative h-[600px] flex items-center justify-center testimonials-container px-4\" data-kid=\"121\">\n      \n      <div class=\"absolute glass-card p-10 w-full max-w-[420px] testimonial-card z-30 shadow-2xl border-white/60 overflow-visible\" data-kid=\"122\">\n        <div class=\"text-5xl text-[#E03A3A] mb-4 font-serif\" data-kid=\"123\">“</div>\n        <p class=\"text-lg italic mb-6 text-[#2D1F1A] font-medium leading-relaxed\" data-kid=\"124\">\"Velonx changed how I build. From simple apps to production-grade SDKs, the community support is unparalleled.\"</p>\n        <div class=\"flex items-center gap-4\" data-kid=\"125\">\n          <img src=\"https://i.pravatar.cc/150?u=a\" class=\"w-14 h-14 rounded-full\" alt=\"Avatar\" data-kid=\"126\">\n          <div data-kid=\"127\">\n            <h4 class=\"font-bold\" data-kid=\"128\">Ananya Tiwari</h4>\n            <p class=\"text-sm opacity-60\" data-kid=\"129\">NIT Silchar • Founder @ BuildAI</p>\n          </div>\n        </div>\n      </div>\n\n      \n      <div class=\"absolute glass-card p-10 w-full max-w-[420px] testimonial-card z-20 shadow-2xl border-white/40 opacity-90 scale-95 translate-x-4 rotate-3 overflow-visible\" data-kid=\"130\">\n        <div class=\"text-5xl text-[#FF8A5B] mb-4 font-serif\" data-kid=\"131\">“</div>\n        <p class=\"text-lg italic mb-6 text-[#2D1F1A] font-medium leading-relaxed\" data-kid=\"132\">\"The 1:1 mentorship sessions were a game changer for my off-campus preparation.\"</p>\n        <div class=\"flex items-center gap-4\" data-kid=\"133\">\n          <img src=\"https://i.pravatar.cc/150?u=b\" class=\"w-14 h-14 rounded-full\" alt=\"Avatar\" data-kid=\"134\">\n          <div data-kid=\"135\">\n            <h4 class=\"font-bold\" data-kid=\"136\">Rohan Mehta</h4>\n            <p class=\"text-sm opacity-60\" data-kid=\"137\">IIIT Hyderabad • SWE @ Google</p>\n          </div>\n        </div>\n      </div>\n\n      \n      <div class=\"absolute glass-card p-10 w-full max-w-[420px] testimonial-card z-10 shadow-2xl border-white/40 opacity-80 scale-90 -translate-x-4 -rotate-3 overflow-visible\" data-kid=\"138\">\n        <div class=\"text-5xl text-[#F7C844] mb-4 font-serif\" data-kid=\"139\">“</div>\n        <p class=\"text-lg italic mb-6 text-[#2D1F1A] font-medium leading-relaxed\" data-kid=\"140\">\"I landed a 33 LPA role from a Tier-3 college. Velonx's skill-first approach works.\"</p>\n        <div class=\"flex items-center gap-4\" data-kid=\"141\">\n          <img src=\"https://i.pravatar.cc/150?u=c\" class=\"w-14 h-14 rounded-full\" alt=\"Avatar\" data-kid=\"142\">\n          <div data-kid=\"143\">\n            <h4 class=\"font-bold\" data-kid=\"144\">Karthik Suresh</h4>\n            <p class=\"text-sm opacity-60\" data-kid=\"145\">BITS Pilani • SWE @ Razorpay</p>\n          </div>\n        </div>\n      </div>\n    </div>\n  </div>\n</section>\n\n\n<footer class=\"py-20 border-t border-sepia/10\" data-kid=\"146\">\n  <div class=\"container-custom\" data-kid=\"147\">\n    <div class=\"flex flex-col md:flex-row justify-between items-start gap-12\" data-kid=\"148\">\n      <div class=\"max-w-xs\" data-kid=\"149\">\n        <h2 class=\"font-heading text-4xl mb-6\" data-kid=\"150\">Velonx.</h2>\n        <p class=\"opacity-60 leading-relaxed\" data-kid=\"151\">Redefining tech careers for students from every corner of India. Skill over tier, always.</p>\n      </div>\n      <div class=\"grid grid-cols-2 sm:grid-cols-3 gap-16\" data-kid=\"152\">\n        <div data-kid=\"153\">\n          <h4 class=\"font-bold mb-6\" data-kid=\"154\">Platform</h4>\n          <ul class=\"space-y-4 opacity-70\" data-kid=\"155\">\n            <li data-kid=\"156\"><a href=\"#\" class=\"hover:text-[#E03A3A]\" data-kid=\"157\">Projects Hub</a></li>\n            <li data-kid=\"158\"><a href=\"#\" class=\"hover:text-[#E03A3A]\" data-kid=\"159\">Mentors</a></li>\n            <li data-kid=\"160\"><a href=\"#\" class=\"hover:text-[#E03A3A]\" data-kid=\"161\">Hackathons</a></li>\n            <li data-kid=\"162\"><a href=\"#\" class=\"hover:text-[#E03A3A]\" data-kid=\"163\">Leaderboard</a></li>\n          </ul>\n        </div>\n        <div data-kid=\"164\">\n          <h4 class=\"font-bold mb-6\" data-kid=\"165\">Community</h4>\n          <ul class=\"space-y-4 opacity-70\" data-kid=\"166\">\n            <li data-kid=\"167\"><a href=\"#\" class=\"hover:text-[#E03A3A]\" data-kid=\"168\">Discord Clan</a></li>\n            <li data-kid=\"169\"><a href=\"#\" class=\"hover:text-[#E03A3A]\" data-kid=\"170\">Success Stories</a></li>\n            <li data-kid=\"171\"><a href=\"#\" class=\"hover:text-[#E03A3A]\" data-kid=\"172\">Blog</a></li>\n            <li data-kid=\"173\"><a href=\"#\" class=\"hover:text-[#E03A3A]\" data-kid=\"174\">Guidelines</a></li>\n          </ul>\n        </div>\n        <div data-kid=\"175\">\n          <h4 class=\"font-bold mb-6\" data-kid=\"176\">Connect</h4>\n          <ul class=\"space-y-4 opacity-70\" data-kid=\"177\">\n            <li data-kid=\"178\"><a href=\"#\" class=\"hover:text-[#E03A3A]\" data-kid=\"179\">X (Twitter)</a></li>\n            <li data-kid=\"180\"><a href=\"#\" class=\"hover:text-[#E03A3A]\" data-kid=\"181\">LinkedIn</a></li>\n            <li data-kid=\"182\"><a href=\"#\" class=\"hover:text-[#E03A3A]\" data-kid=\"183\">Instagram</a></li>\n          </ul>\n        </div>\n      </div>\n    </div>\n    <div class=\"mt-20 pt-10 border-t border-sepia/5 flex flex-col sm:flex-row justify-between items-center gap-6\" data-kid=\"184\">\n       <p class=\"text-sm opacity-50\" data-kid=\"185\">© 2024 Velonx. All rights reserved.</p>\n       <div class=\"flex gap-8 text-sm opacity-50\" data-kid=\"186\">\n         <a href=\"#\" class=\"hover:text-sepia\" data-kid=\"187\">Privacy Policy</a>\n         <a href=\"#\" class=\"hover:text-sepia\" data-kid=\"188\">Terms of Service</a>\n       </div>\n    </div>\n  </div>\n</footer>\n\n<script type=\"module\" data-kid=\"189\">\n  import { animate, scroll, inView, stagger } from \"https://cdn.jsdelivr.net/npm/motion@12/+esm\";\n\n  // Hero Animations\n  animate(\".hero-title\", { y: [100, 0], opacity: [0, 1] }, { duration: 1, easing: [0.16, 1, 0.3, 1] });\n  animate(\".hero-content p, .hero-content .inline-flex, .hero-content button\", { y: [30, 0], opacity: [0, 1] }, { delay: stagger(0.1, { start: 0.4 }), duration: 0.8 });\n  animate(\".hero-visual\", { scale: [0.8, 1], opacity: [0, 1] }, { duration: 1.2, easing: \"ease-out\", delay: 0.2 });\n\n  // Spring-based Floating animations\n  animate(\".floating-card-1\", { y: [-15, 15], x: [5, -5] }, { duration: 4, repeat: Infinity, direction: \"alternate\", easing: \"ease-in-out\" });\n  animate(\".floating-card-2\", { y: [15, -15], x: [-5, 5] }, { duration: 5, repeat: Infinity, direction: \"alternate\", easing: \"ease-in-out\", delay: 0.5 });\n  animate(\".floating-card-3\", { y: [-10, 10] }, { duration: 3.5, repeat: Infinity, direction: \"alternate\", easing: \"ease-in-out\", delay: 1 });\n\n  // Interactive Hover Springs\n  document.querySelectorAll(\".bento-card, .btn-primary, .btn-secondary, .journey-dot\").forEach(el => {\n    el.addEventListener(\"mouseenter\", () => animate(el, { scale: 1.05, y: -8 }, { type: \"spring\", stiffness: 300, damping: 15 }));\n    el.addEventListener(\"mouseleave\", () => animate(el, { scale: 1, y: 0 }, { type: \"spring\", stiffness: 300, damping: 15 }));\n  });\n\n  // Journey Path Draw on Scroll\n  const path = document.querySelector(\"#journeyPath\");\n  scroll(({ y }) => {\n    path.style.strokeDasharray = \"1 1\";\n    path.style.strokeDashoffset = 1 - y.progress;\n  }, {\n    target: document.querySelector(\".journey-item\").parentElement,\n    offset: [\"start center\", \"end center\"]\n  });\n\n  // Journey Items animation\n  inView(\".journey-item\", (info) => {\n    animate(info.target, { opacity: [0, 1], y: [50, 0] }, { duration: 0.8, easing: \"ease-out\" });\n  });\n\n  // Bento Cards lift\n  inView(\".bento-card\", (info) => {\n    animate(info.target, { opacity: [0, 1], scale: [0.9, 1], y: [50, 0] }, { duration: 0.8, easing: [0.175, 0.885, 0.32, 1.275] });\n  });\n\n  // Testimonials Fan-Out on Scroll\n  const tCards = document.querySelectorAll(\".testimonial-card\");\n  scroll(({ y }) => {\n    const p = y.progress;\n    const spread = window.innerWidth < 768 ? 0 : 440;\n    if (p > 0.05) {\n      animate(tCards[0], { y: -20 * p, rotate: 0, scale: 1, opacity: 1 }, { duration: 0.1 });\n      animate(tCards[1], { x: spread * Math.min(p * 4, 1), rotate: 6 * Math.min(p * 4, 1), scale: 1, opacity: 1 }, { duration: 0.1 });\n      animate(tCards[2], { x: -spread * Math.min(p * 4, 1), rotate: -6 * Math.min(p * 4, 1), scale: 1, opacity: 1 }, { duration: 0.1 });\n    }\n  }, {\n    target: document.querySelector(\".testimonials-container\"),\n    offset: [\"start 75%\", \"center center\"]\n  });\n\n</script>\n",
