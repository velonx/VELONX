nter-events-none group-hover:opacity-100 group-hover:scale-100 transition-all duration-500 origin-bottom shadow-[0_40px_100px_rgba(167,139,250,0.1)]\" data-kid=\"158\">\n                        <div class=\"flex justify-between items-start mb-4\" data-kid=\"159\">\n                            <span class=\"text-[10px] font-black uppercase tracking-widest text-[var(--color-secondary)]\" data-kid=\"160\">Meta Lead Designer</span>\n                        </div>\n                        <h4 class=\"font-clash text-2xl font-bold mb-2\" data-kid=\"161\">Sara Chen</h4>\n                        <p class=\"text-sm text-[var(--color-fg)]/60 leading-relaxed mb-6\" data-kid=\"162\">Expert in scalable design systems and frontend performance optimization.</p>\n                        <button class=\"w-full py-3 bg-[var(--color-secondary)] text-[#120921] rounded-2xl font-bold text-sm\" data-kid=\"163\">Book 1:1 Session</button>\n                    </div>\n                </div>\n            </div>\n\n            <div class=\"mentor-float absolute bottom-[15%] left-1/2 -translate-x-1/2 group\" style=\"animation-delay: -5s;\" data-kid=\"164\">\n                <div class=\"relative\" data-kid=\"165\">\n                    <img src=\"https://i.pravatar.cc/120?u=marcus-m\" class=\"w-28 h-24 rounded-full border-4 border-white/5 grayscale group-hover:grayscale-0 group-hover:border-[var(--color-primary)] transition-all duration-500 cursor-pointer shadow-2xl object-cover\" data-kid=\"166\">\n                    <div class=\"absolute top-full left-1/2 -translate-x-1/2 mt-6 w-72 glass-deep p-8 rounded-[32px] opacity-0 scale-50 pointer-events-none group-hover:opacity-100 group-hover:scale-100 transition-all duration-500 origin-top shadow-[0_40px_100px_rgba(34,197,94,0.1)]\" data-kid=\"167\">\n                        <div class=\"flex justify-between items-start mb-4\" data-kid=\"168\">\n                            <span class=\"text-[10px] font-black uppercase tracking-widest text-[var(--color-primary)]\" data-kid=\"169\">Open Source Lead</span>\n                        </div>\n                        <h4 class=\"font-clash text-2xl font-bold mb-2\" data-kid=\"170\">Marcus Thorne</h4>\n                        <p class=\"text-sm text-[var(--color-fg)]/60 leading-relaxed mb-6\" data-kid=\"171\">Former Rust foundation contributor and Web3 core architect.</p>\n                        <button class=\"w-full py-3 bg-[var(--color-primary)] text-[#120921] rounded-2xl font-bold text-sm\" data-kid=\"172\">Book 1:1 Session</button>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>\n\n\n<section id=\"cta\" class=\"py-48 bg-[#120921] relative overflow-hidden\" data-kid=\"173\">\n    <div class=\"hero-orb absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[1200px] h-[600px] bg-[var(--color-primary)]/10 rounded-full blur-[180px]\" data-kid=\"174\"></div>\n    \n    <div class=\"container mx-auto px-6 relative z-10 text-center\" data-kid=\"175\">\n        <h2 class=\"font-clash text-6xl md:text-8xl font-bold mb-12 reveal-y\" data-kid=\"176\">Ready to Rewrite<br data-kid=\"177\">Your Future?</h2>\n        <p class=\"text-[var(--color-fg)]/50 text-xl max-w-xl mx-auto mb-16 reveal-y stagger-1\" data-kid=\"178\">Join 15,000+ students already scaling their careers with Velonx.</p>\n        \n        <div class=\"flex flex-col sm:flex-row gap-6 justify-center items-center reveal-y stagger-2\" data-kid=\"179\">\n            <button class=\"magnetic-cta px-16 py-6 bg-[var(--color-primary)] text-[#120921] font-bold rounded-full text-lg hover:scale-105 transition-all\" data-kid=\"180\">Sign Up Free</button>\n            <button class=\"magnetic-cta px-16 py-6 border border-[var(--color-fg)]/20 rounded-full font-bold text-lg hover:bg-white/5 transition-all\" data-kid=\"181\">Talk to a Mentor</button>\n        </div>\n    </div>\n</section>\n\n\n<footer class=\"py-16 bg-[#0D0719] border-t border-white/5\" data-kid=\"182\">\n    <div class=\"container mx-auto px-6 flex flex-col md:flex-row justify-between items-center gap-12\" data-kid=\"183\">\n        <div data-kid=\"184\">\n            <span class=\"font-clash text-3xl font-bold tracking-tighter\" data-kid=\"185\">VELONX</span>\n            <p class=\"text-[var(--color-fg)]/30 text-xs mt-2 uppercase tracking-widest\" data-kid=\"186\">© 2024 Deep Tech Platform</p>\n        </div>\n        \n        <div class=\"flex gap-12\" data-kid=\"187\">\n            <a href=\"#\" class=\"text-sm text-[var(--color-fg)]/50 hover:text-[var(--color-primary)] transition-colors\" data-kid=\"188\">Privacy</a>\n            <a href=\"#\" class=\"text-sm text-[var(--color-fg)]/50 hover:text-[var(--color-primary)] transition-colors\" data-kid=\"189\">Terms</a>\n            <a href=\"#\" class=\"text-sm text-[var(--color-fg)]/50 hover:text-[var(--color-primary)] transition-colors\" data-kid=\"190\">Careers</a>\n            <a href=\"#\" class=\"text-sm text-[var(--color-fg)]/50 hover:text-[var(--color-primary)] transition-colors\" data-kid=\"191\">Discord</a>\n        </div>\n    </div>\n</footer>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"192\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"193\"></script>\n<script data-kid=\"194\">\n    gsap.registerPlugin(ScrollTrigger);\n\n    // Reveal animations\n    gsap.utils.toArray('.reveal-y').forEach((el) => {\n        gsap.from(el, {\n            y: 50,\n            opacity: 0,\n            duration: 1.2,\n            ease: \"power4.out\",\n            scrollTrigger: {\n                trigger: el,\n                start: \"top 90%\",\n            }\n        });\n    });\n\n    gsap.utils.toArray('.reveal-stagger').forEach((container) => {\n        gsap.from(container.children, {\n            y: 30,\n            opacity: 0,\n            duration: 1,\n            stagger: 0.15,\n            ease: \"back.out(1.7)\",\n            scrollTrigger: {\n                trigger: container,\n                start: \"top 85%\",\n            }\n        });\n    });\n\n    // Magnetic CTA\n    const ctas = document.querySelectorAll('.magnetic-cta');\n    ctas.forEach(cta => {\n        cta.addEventListener('mousemove', (e) => {\n            const rect = cta.getBoundingClientRect();\n            const x = e.clientX - rect.left - rect.width / 2;\n            const y = e.clientY - rect.top - rect.height / 2;\n            gsap.to(cta, {\n                x: x * 0.2,\n                y: y * 0.2,\n                duration: 0.3,\n                ease: \"power2.out\"\n            });\n        });\n        cta.addEventListener('mouseleave', () => {\n            gsap.to(cta, {\n                x: 0,\n                y: 0,\n                duration: 0.5,\n                ease: \"elastic.out(1, 0.3)\"\n            });\n        });\n    });\n\n    // Hero Orbs Float\n    gsap.to('.hero-orb', {\n        x: 'random(-50, 50)',\n        y: 'random(-50, 50)',\n        duration: 'random(5, 8)',\n        repeat: -1,\n        yoyo: true,\n        ease: 'sine.inOut'\n    });\n\n    // Mentor Float\n    gsap.to('.mentor-float', {\n        y: -20,\n        duration: 3,\n        repeat: -1,\n        yoyo: true,\n        ease: \"sine.inOut\"\n    });\n\n    // Path Animation for Journey Stepper\n    gsap.from(\"#stepper-path\", {\n        strokeDashoffset: 1000,\n        duration: 2,\n        ease: \"none\",\n        scrollTrigger: {\n            trigger: \"#journey\",\n            start: \"top 60%\",\n            end: \"bottom 20%\",\n            scrub: 1\n        }\n    });\n\n    // Marquee continuous\n    gsap.to(\".animate-marquee\", {\n        xPercent: -50,\n        repeat: -1,\n        duration: 20,\n        ease: \"none\"\n    });\n\n</script>\n",
