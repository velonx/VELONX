      "html": "\n<style data-kid=\"0\">\n    @import url('https://api.fontshare.com/v2/css?f[]=clash-display@400,500,600,700&display=swap');\n    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');\n    @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n    :root {\n        --color-bg: #120921;\n        --color-fg: #F8F4EC;\n        --color-primary: #22C55E;\n        --color-secondary: #A78BFA;\n    }\n\n    body {\n        background-color: var(--color-bg);\n        color: var(--color-fg);\n        font-family: 'Inter', sans-serif;\n        overflow-x: hidden;\n    }\n\n    .font-clash { font-family: 'Clash Display', sans-serif; }\n\n    /* Noise Overlay */\n    .noise-overlay {\n        position: fixed;\n        top: 0;\n        left: 0;\n        width: 100%;\n        height: 100%;\n        pointer-events: none;\n        z-index: 9999;\n        opacity: 0.05;\n        background-image: url(\"data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E\");\n    }\n\n    /* Bento Shadows */\n    .bento-card-shadow {\n        box-shadow: 0 60px 120px -30px rgba(167, 139, 250, 0.25);\n    }\n\n    .bento-card-shadow-green {\n        box-shadow: 0 60px 120px -30px rgba(34, 197, 94, 0.2);\n    }\n\n    /* Custom Glass */\n    .glass-deep {\n        background: rgba(26, 14, 46, 0.6);\n        backdrop-filter: blur(20px);\n        border: 1px solid rgba(248, 244, 236, 0.05);\n    }\n\n    .bento-hover {\n        transition: all 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);\n    }\n    .bento-hover:hover {\n        transform: translateY(-8px) scale(1.01);\n        border-color: rgba(167, 139, 250, 0.3);\n    }\n\n    /* Scrollbar */\n    ::-webkit-scrollbar { width: 8px; }\n    ::-webkit-scrollbar-track { background: var(--color-bg); }\n    ::-webkit-scrollbar-thumb { background: rgba(167, 139, 250, 0.3); border-radius: 10px; }\n    ::-webkit-scrollbar-thumb:hover { background: rgba(167, 139, 250, 0.5); }\n</style>\n\n<div class=\"noise-overlay\" data-kid=\"1\"></div>\n\n\n<section id=\"hero\" class=\"relative min-h-screen flex items-center justify-center overflow-hidden\" data-kid=\"2\">\n    \n    <div class=\"absolute inset-0 z-0 opacity-20 overflow-hidden\" data-kid=\"3\">\n        <video src=\"https://videos.pexels.com/video-files/34268137/14519231_640_360_60fps.mp4\" poster=\"https://images.pexels.com/videos/34268137/4k-dev-34268137.jpeg?auto=compress&cs=tinysrgb&fit=crop&h=630&w=1200\" autoplay muted loop playsinline class=\"w-full h-full object-cover\" data-kid=\"4\"></video>\n    </div>\n\n    \n    <div class=\"hero-orb absolute top-[-10%] left-[10%] w-[500px] h-[500px] bg-[#22C55E]/20 rounded-full blur-[120px]\" data-kid=\"5\"></div>\n    <div class=\"hero-orb absolute bottom-[-10%] right-[10%] w-[600px] h-[600px] bg-[#A78BFA]/20 rounded-full blur-[120px]\" data-kid=\"6\"></div>\n\n    \n    <div class=\"container mx-auto px-6 relative z-10 flex flex-col items-center text-center\" data-kid=\"7\">\n        <div class=\"mb-6 inline-flex items-center gap-2 px-4 py-2 rounded-full border border-[var(--color-primary)]/20 bg-[var(--color-primary)]/5 text-xs font-bold text-[var(--color-primary)] uppercase tracking-widest reveal-stagger\" data-kid=\"8\">\n            <span class=\"w-2 h-2 rounded-full bg-[var(--color-primary)] animate-ping\" data-kid=\"9\"></span>\n            Deep Tech Redesign V2\n        </div>\n        \n        <h1 class=\"font-clash text-6xl md:text-8xl lg:text-[140px] font-bold leading-[0.9] tracking-tighter text-[var(--color-fg)] mb-8 reveal-y\" data-kid=\"10\">\n            Your Future<br data-kid=\"11\">Has No Limits.\n        </h1>\n\n        <p class=\"text-lg md:text-xl text-[var(--color-fg)]/60 max-w-2xl mb-12 reveal-y stagger-1\" data-kid=\"12\">\n            Bridging the gap for Tier-2 & Tier-3 students with a next-gen deep tech platform for high-growth careers.\n        </p>\n\n        <div class=\"flex flex-col sm:flex-row gap-6 reveal-y stagger-2\" data-kid=\"13\">\n            <button class=\"magnetic-cta group relative px-10 py-5 bg-[var(--color-primary)] text-[#120921] font-bold rounded-full overflow-hidden cursor-pointer\" data-kid=\"14\">\n                <span class=\"relative z-10 flex items-center gap-2\" data-kid=\"15\">Join Free Today <i class=\"ti ti-arrow-right\" data-kid=\"16\"></i></span>\n                <div class=\"absolute inset-0 bg-white/20 translate-y-full group-hover:translate-y-0 transition-transform duration-500\" data-kid=\"17\"></div>\n            </button>\n            <button class=\"magnetic-cta px-10 py-5 border border-[var(--color-fg)]/20 rounded-full font-bold hover:bg-[var(--color-fg)]/10 cursor-pointer\" data-kid=\"18\">\n                Explore The Path\n            </button>\n        </div>\n\n        \n        <div class=\"mt-24 w-full overflow-hidden whitespace-nowrap opacity-40 select-none\" data-kid=\"19\">\n            <div class=\"inline-flex gap-24 animate-marquee py-4\" data-kid=\"20\">\n                <span class=\"font-clash text-2xl font-bold uppercase tracking-widest text-[var(--color-fg)]\" data-kid=\"21\">Web3 Architecture</span>\n                <span class=\"font-clash text-2xl font-bold uppercase tracking-widest text-[var(--color-primary)]\" data-kid=\"22\">Distributed Systems</span>\n                <span class=\"font-clash text-2xl font-bold uppercase tracking-widest text-[var(--color-fg)]\" data-kid=\"23\">Machine Learning</span>\n                <span class=\"font-clash text-2xl font-bold uppercase tracking-widest text-[var(--color-secondary)]\" data-kid=\"24\">Systems Design</span>\n                <span class=\"font-clash text-2xl font-bold uppercase tracking-widest text-[var(--color-fg)]\" data-kid=\"25\">Backend Scaling</span>\n                <span class=\"font-clash text-2xl font-bold uppercase tracking-widest text-[var(--color-primary)]\" data-kid=\"26\">Cloud Native</span>\n                \n                <span class=\"font-clash text-2xl font-bold uppercase tracking-widest text-[var(--color-fg)]\" data-kid=\"27\">Web3 Architecture</span>\n                <span class=\"font-clash text-2xl font-bold uppercase tracking-widest text-[var(--color-primary)]\" data-kid=\"28\">Distributed Systems</span>\n                <span class=\"font-clash text-2xl font-bold uppercase tracking-widest text-[var(--color-fg)]\" data-kid=\"29\">Machine Learning</span>\n                <span class=\"font-clash text-2xl font-bold uppercase tracking-widest text-[var(--color-secondary)]\" data-kid=\"30\">Systems Design</span>\n                <span class=\"font-clash text-2xl font-bold uppercase tracking-widest text-[var(--color-fg)]\" data-kid=\"31\">Backend Scaling</span>\n                <span class=\"font-clash text-2xl font-bold uppercase tracking-widest text-[var(--color-primary)]\" data-kid=\"32\">Cloud Native</span>\n            </div>\n        </div>\n    </div>\n</section>\n\n\n<section id=\"journey\" class=\"py-32 relative overflow-hidden\" data-kid=\"33\">\n    <div class=\"container mx-auto px-6\" data-kid=\"34\">\n        <div class=\"text-center mb-32 reveal-y\" data-kid=\"35\">\n            <h2 class=\"font-clash text-5xl md:text-6xl font-bold mb-6\" data-kid=\"36\">The Journey Unscrambled</h2>\n            <p class=\"text-[var(--color-fg)]/50 max-w-xl mx-auto\" data-kid=\"37\">From aspiring student to industry expert, we weave the path for you.</p>\n        </div>\n\n        <div class=\"relative max-w-6xl mx-auto min-h-[1200px]\" data-kid=\"38\">\n            \n            <svg class=\"absolute top-0 left-0 w-full h-full pointer-events-none z-0 overflow-visible\" viewBox=\"0 0 1000 1200\" fill=\"none\" data-kid=\"39\">\n                <path id=\"stepper-path\" d=\"M150,150 C450,150 850,300 850,500 C850,700 150,750 150,950 C150,1150 650,1150 850,1150\" stroke=\"url(#gradient-path)\" stroke-width=\"4\" stroke-dasharray=\"12 18\" class=\"opacity-40\" data-kid=\"40\"></path>\n                <defs data-kid=\"41\">\n                    <linearGradient id=\"gradient-path\" x1=\"0%\" y1=\"0%\" x2=\"0%\" y2=\"100%\" data-kid=\"42\">\n                        <stop offset=\"0%\" stop-color=\"var(--color-primary)\" data-kid=\"43\"></stop>\n                        <stop offset=\"50%\" stop-color=\"var(--color-secondary)\" data-kid=\"44\"></stop>\n                        <stop offset=\"100%\" stop-color=\"var(--color-primary)\" data-kid=\"45\"></stop>\n                    </linearGradient>\n                </defs>\n                \n                <circle r=\"6\" fill=\"var(--color-primary)\" data-kid=\"46\">\n                    <animateMotion dur=\"8s\" repeatCount=\"indefinite\" data-kid=\"47\">\n                        <mpath href=\"#stepper-path\" data-kid=\"48\"></mpath>\n                    </animateMotion>\n                    <animate attributeName=\"opacity\" values=\"0.8;0.3;0.8\" dur=\"2s\" repeatCount=\"indefinite\" data-kid=\"49\"></animate>\n                </circle>\n            </svg>\n\n            \n            <div class=\"space-y-48 relative z-10 pt-20\" data-kid=\"50\">\n                \n                <div class=\"flex justify-start items-center gap-12 reveal-stagger px-12\" data-kid=\"51\">\n                    <div class=\"relative group bg-[#1A0E2E] border-2 border-[var(--color-fg)]/5 p-10 rounded-[40px] w-full max-w-sm bento-card-shadow transition-all duration-500 hover:border-[var(--color-primary)]/40 hover:-translate-y-4\" data-kid=\"52\">\n                        <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/delapouite/hexagonal-nut.svg\" class=\"absolute -z-10 -bottom-8 -right-8 w-32 h-32 opacity-[0.03] text-[var(--color-primary)] rotate-12\" style=\"filter: invert(1);\" data-kid=\"53\">\n                        <div class=\"absolute -top-10 -left-6 w-20 h-20 bg-[var(--color-primary)]/10 rounded-3xl flex items-center justify-center border border-[var(--color-primary)]/20 shadow-xl\" data-kid=\"54\">\n                            <i class=\"ti ti-puzzle text-4xl text-[var(--color-primary)]\" data-kid=\"55\"></i>\n                        </div>\n                        <div class=\"mt-4\" data-kid=\"56\">\n                            <h3 class=\"font-clash text-3xl font-bold mb-4\" data-kid=\"57\">Build Your Core</h3>\n                            <p class=\"text-[var(--color-fg)]/60 leading-relaxed\" data-kid=\"58\">Design your unique builder profile that highlights proof-of-work over boring certificates.</p>\n                        </div>\n                    </div>\n                </div>\n\n                \n                <div class=\"flex justify-end items-center gap-12 reveal-stagger px-12\" data-kid=\"59\">\n                    <div class=\"relative group bg-[#1A0E2E] border-2 border-[var(--color-fg)]/5 p-10 rounded-[40px] w-full max-w-sm bento-card-shadow transition-all duration-500 hover:border-[var(--color-secondary)]/40 hover:-translate-y-4\" data-kid=\"60\">\n                        <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/skoll/hexes.svg\" class=\"absolute -z-10 -bottom-8 -left-8 w-32 h-32 opacity-[0.03] text-[var(--color-secondary)] -rotate-12\" style=\"filter: invert(1);\" data-kid=\"61\">\n                        <div class=\"absolute -top-10 -right-6 w-20 h-20 bg-[var(--color-secondary)]/10 rounded-3xl flex items-center justify-center border border-[var(--color-secondary)]/20 shadow-xl\" data-kid=\"62\">\n                            <i class=\"ti ti-trending-up text-4xl text-[var(--color-secondary)]\" data-kid=\"63\"></i>\n                        </div>\n                        <div class=\"mt-4\" data-kid=\"64\">\n                            <h3 class=\"font-c