}

// ============================================================
// Swag Store Models
// ============================================================

enum SwagCategory {
  NOTEBOOK
  DIARY
  BOTTLE
  BAG
  PLANT
  LAMP
  STATIONERY
  APPAREL
  OTHER
}

enum SwagOrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

// SwagItem — product catalog managed by admins
model SwagItem {
  id          String       @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  description String
  imageUrl    String?
  category    SwagCategory
  xpCost      Int
  stock       Int          @default(-1) // -1 = unlimited
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  orders SwagOrder[]

  @@index([isActive, category])
  @@map("swag_items")
}

// SwagOrder — purchase records with delivery details
model SwagOrder {
  id       String          @id @default(auto()) @map("_id") @db.ObjectId
  userId   String          @db.ObjectId
  itemId   String          @db.ObjectId
  quantity Int             @default(1)
