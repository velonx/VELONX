// Verification Enums
enum VerificationType {
  INTERNSHIP
  EVENT_PROJECT
  CONTRIBUTION
  ACHIEVEMENT
  EXCELLENCE
}

// Verification Model
model Verification {
  id                String           @id @default(auto()) @map("_id") @db.ObjectId
  userId            String           @db.ObjectId
  type              VerificationType
  title             String
  description       String?
  issuedAt          DateTime         @default(now())
  expiryDate        DateTime?
  issuerId          String           @db.ObjectId
  verificationToken String           @unique
  metadata          Json?            // For additional details like project links, specific roles, etc.
  
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  // Relations
  user   User @relation(fields: [userId], references: [id])
  // We can't easily relate to another User as issuer without naming it specifically
  // and there might not be a reverse relation needed.
  
  @@index([userId])
  @@map("verifications")
}

// ============================================
// LEARNING PATHS MODELS
// ============================================

model LearningPath {
  id             String             @id @default(auto()) @map("_id") @db.ObjectId
  title          String
  description    String
  level          String             // "Beginner" | "Intermediate" | "Advanced"
  duration       String             // e.g., "6 Weeks"
  badgeName      String?            // Name of the skill badge earned (optional)
  badgeImageUrl  String?            // Image URL for the skill badge (optional)
  hasCertificate Boolean            @default(false)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  modules       Module[]
  userProgress  UserPathProgress[]
  testSchedules TestSchedule[]

  @@map("learning_paths")
}

model Module {
  id                 String               @id @default(auto()) @map("_id") @db.ObjectId
  pathId             String               @db.ObjectId
  title              String
  description        String
  link               String               // Destination URL set by admin
  duration           String               // e.g. "4 hours"
  order              Int                  @default(0)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  learningPath       LearningPath         @relation(fields: [pathId], references: [id], onDelete: Cascade)
  userModuleProgress UserModuleProgress[]

  @@index([pathId])
  @@map("modules")
}

model UserPathProgress {
  id               String       @id @default(auto()) @map("_id") @db.ObjectId
  userId           String       @db.ObjectId
  pathId           String       @db.ObjectId
  completed        Boolean      @default(false)
  completedAt      DateTime?
  certificateEarned Boolean     @default(false)
  certificateUrl   String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  learningPath     LearningPath @relation(fields: [pathId], references: [id], onDelete: Cascade)

  @@unique([userId, pathId])
  @@index([userId])
  @@index([pathId])
  @@map("user_path_progress")
}

model UserModuleProgress {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @db.ObjectId
  moduleId    String   @db.ObjectId
  completed   Boolean  @default(true)
  completedAt DateTime @default(now())

  module      Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, moduleId])
  @@index([userId])
  @@index([moduleId])
  @@map("user_module_progress")
}

model TestSchedule {
  id           String       @id @default(auto()) @map("_id") @db.ObjectId
  userId       String       @db.ObjectId
  pathId       String       @db.ObjectId
  testDate     DateTime
  status       String       @default("SCHEDULED") // "SCHEDULED" | "PASSED" | "FAILED"
  score        Int?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  learningPath LearningPath @relation(fields: [pathId], references: [id], onDelete: Cascade)

  @@unique([userId, pathId])
  @@index([userId])
  @@index([pathId])
  @@map("test_schedules")
}

// ============================================
// EMAIL NOTIFICATION PREFERENCES
// ============================================

// Categories of email notifications users can control
enum EmailNotificationCategory {
  JOB_POSTED          // A new job/opportunity was posted
  EVENT_POSTED        // A new event was published
  SWAG_ANNOUNCED      // A new swag drop was announced
  POST_COMMENT        // Someone commented on your post
  PROJECT_UPDATED     // A project you belong to was updated
  RESOURCE_ADDED      // A new resource was added to the library
  BLOG_POST_PUBLISHED // A new blog post was published
}

// Frequency options per category
enum EmailNotificationFrequency {
  INSTANT // Send immediately when the event fires
  DAILY   // Bundle into a daily digest email
  WEEKLY  // Bundle into a weekly digest email
  OFF     // Do not send any email for this category
}

// Per-user, per-category email notification preference
// One row per (userId, category) pair.
// When no row exists the system uses the per-category default frequency.
model EmailNotificationPreference {
  id        String                       @id @default(auto()) @map("_id") @db.ObjectId
  userId    String                       @db.ObjectId
  category  EmailNotificationCategory
  frequency EmailNotificationFrequency
  updatedAt DateTime                     @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category])
  @@index([userId])
  @@map("email_notification_preferences")
}

// ============================================
// NETWORKING & DIRECT MESSAGING MODELS
// ============================================

// Connection Model (LinkedIn-style bidirectional connections)
model Connection {
  id          String           @id @default(auto()) @map("_id") @db.ObjectId
  senderId    String           @db.ObjectId
  receiverId  String           @db.ObjectId
  status      ConnectionStatus @default(PENDING)
  message     String?          // Optional connection request note
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  sender   User @relation("ConnectionsSent", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("ConnectionsReceived", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId])
  @@index([senderId, status])
  @@index([receiverId, status])
  @@map("connections")
}

// Direct Message Model (1:1 private messages)
model DirectMessage {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  senderId    String   @db.ObjectId
  receiverId  String   @db.ObjectId
  content     String
  isRead      Boolean  @default(false)
  isEdited    Boolean  @default(false)
  isDeleted   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sender   User @relation("MessagesSent", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("MessagesReceived", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([senderId, receiverId, createdAt])
  @@index([receiverId, isRead])
  @@map("direct_messages")
}

// Conversation Model (tracks 1:1 chat threads)
model Conversation {
  id                 String   @id @default(auto()) @map("_id") @db.ObjectId
  participant1Id     String   @db.ObjectId
  participant2Id     String   @db.ObjectId
  lastMessageAt      DateTime @default(now())
  lastMessagePreview String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  participant1 User @relation("Conversations1", fields: [participant1Id], references: [id], onDelete: Cascade)
  participant2 User @relation("Conversations2", fields: [participant2Id], references: [id], onDelete: Cascade)

  @@unique([participant1Id, participant2Id])
  @@index([participant1Id, lastMessageAt])
  @@index([participant2Id, lastMessageAt])
  @@map("conversations")
}
