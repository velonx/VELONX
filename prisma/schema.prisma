  updatedAt DateTime @updatedAt

  user User     @relation(fields: [userId], references: [id])
  item SwagItem @relation(fields: [itemId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("swag_orders")
